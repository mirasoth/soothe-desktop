{
  "name": "soothe-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Electron + React desktop client for Soothe (RFC-505).",
  "main": "out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "NODE_OPTIONS= electron-vite dev",
    "build": "NODE_OPTIONS= electron-vite build",
    "package": "NODE_OPTIONS= electron-vite build && NODE_OPTIONS= electron-builder",
    "package:mac": "NODE_OPTIONS= electron-vite build && NODE_OPTIONS= electron-builder --mac",
    "lint": "eslint --ext .ts,.tsx src",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.node.json"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "cmdk": "^1.0.4",
    "diff": "^7.0.0",
    "electron-store": "^10.0.1",
    "react": "^18.3.1",
    "react-diff-view": "^3.2.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "react-virtuoso": "^4.12.3",
    "remark-gfm": "^4.0.0",
    "shiki": "^1.24.0",
    "soothe-client-typescript": "file:../../client/typescript",
    "tailwind-merge": "^2.5.4",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@testing-library/react": "^16.1.0",
    "@types/diff": "^6.0.0",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "eslint": "^9.17.0",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.49",
    "prettier": "^3.4.2",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
